<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
   line_follower.xml  —  Blockly XML for the "follow the line" block
   Backed by: LineFollowerPipeline.java
  ============================================================================

   This file contains TWO separate XML trees. Use whichever you need:

     1. <xml id="toolbox">   the flyout menu students drag the block out of
     2. <xml id="workspace"> an example saved program

   NOTE: XML cannot define what the block IS (its shape, colour, fields).
   That lives in the JSON definition, which must be registered first:

       {
         "type": "line_follower_follow",
         "message0": "follow the line on power %1",
         "args0": [
           { "type": "input_value", "name": "POWER", "check": "Number" }
         ],
         "inputsInline": true,
         "previousStatement": null,
         "nextStatement": null,
         "colour": 30,
         "tooltip": "Drives along the line. Power 0-100 sets speed on straights. Steering is automatic and the robot slows itself into curves."
       }

   The <shadow type="math_number"> below puts a default 50 in the socket, so
   the block works the moment a student drags it out with nothing plugged in.
  ============================================================================
-->


<!-- ==========================================================================
     1. TOOLBOX  —  what students see in the flyout
     ====================================================================== -->
<xml xmlns="https://developers.google.com/blockly/xml" id="toolbox" style="display: none">

  <category name="Line Following" colour="30">
    <block type="line_follower_follow">
      <value name="POWER">
        <shadow type="math_number">
          <field name="NUM">50</field>
        </shadow>
      </value>
    </block>
  </category>

  <category name="Loops" colour="120">
    <block type="controls_whileUntil">
      <field name="MODE">WHILE</field>
    </block>
    <block type="controls_repeat_ext">
      <value name="TIMES">
        <shadow type="math_number">
          <field name="NUM">10</field>
        </shadow>
      </value>
    </block>
  </category>

  <category name="Math" colour="230">
    <block type="math_number">
      <field name="NUM">50</field>
    </block>
  </category>

</xml>


<!-- ==========================================================================
     2. EXAMPLE WORKSPACE  —  a saved program: follow the line at power 80
     ====================================================================== -->
<xml xmlns="https://developers.google.com/blockly/xml" id="workspace" style="display: none">

  <block type="controls_whileUntil" x="60" y="60">
    <field name="MODE">WHILE</field>
    <value name="BOOL">
      <block type="logic_boolean">
        <field name="BOOL">TRUE</field>
      </block>
    </value>
    <statement name="DO">
      <block type="line_follower_follow">
        <value name="POWER">
          <shadow type="math_number">
            <field name="NUM">80</field>
          </shadow>
        </value>
      </block>
    </statement>
  </block>

</xml>


<!--
  ============================================================================
   GENERATED JAVA from the example workspace above:

       while (true) {
           LineFollowerHelper.followLine(80);
       }

   At power 80:
     straight   -> tracking 100 -> drives at 80
     curve      -> tracking  40 -> drives at 32   (slows by itself)
     line lost  -> tracking   0 -> stops
  ============================================================================
-->
