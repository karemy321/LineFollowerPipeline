<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- CameraX live preview — fills the screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ⊥ Sensor overlay — drawn transparently on top of the preview -->
    <com.example.firstproject.OverlayView
        android:id="@+id/overlay_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:focusable="false" />

    <!-- ── HUD overlay at the bottom of the screen ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC0D0D1A"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Row 1: Steering -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:text="STEER"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center" />

            <!--
                SeekBar range [0, 200]; thumb at 100 = centred (steering = 0).
                User interaction is disabled — it acts as a visual position indicator.
            -->
            <SeekBar
                android:id="@+id/seek_steering"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="200"
                android:progress="100"
                android:clickable="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:progressTint="#334455"
                android:thumbTint="#00E676" />

            <TextView
                android:id="@+id/tv_steering"
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:text="  +0"
                android:textColor="#00E676"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center" />
        </LinearLayout>

        <!-- Row 2: Track continuity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:text="TRACK"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center" />

            <ProgressBar
                android:id="@+id/pb_track"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="18dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressTint="#00E676"
                android:progressBackgroundTint="#444444" />

            <TextView
                android:id="@+id/tv_intersection"
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:text=" 0%"
                android:textColor="#00E676"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center" />
        </LinearLayout>

        <!-- Row 3: Status line -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INITIALISING…"
            android:textColor="#888888"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingTop="2dp" />

        <!-- Row 4: FPS + cumulative frames + elapsed time -->
        <TextView
            android:id="@+id/tv_frames"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FPS: 0    total: 0    time: 0.0s"
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingTop="2dp" />

    </LinearLayout>

</FrameLayout>